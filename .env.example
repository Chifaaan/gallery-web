# ──────────────────────────────────────────────────────────────
# Docker Compose Environment Variables
# Copy this to .env and adjust values as needed
# ──────────────────────────────────────────────────────────────

# ── Ports ──────────────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=3000

# ── API Configuration ─────────────────────────────────────────
MODEL_DIR=./exported_model
DEVICE=cpu

# ── Frontend Build-time ───────────────────────────────────────
# URL yang diakses browser — ganti ke domain production jika deploy ke server
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
